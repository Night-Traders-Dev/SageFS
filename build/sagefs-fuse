#!/usr/bin/env python3
"""
SageFS FUSE bridge — mounts a hex-text SageFS image as a userspace
filesystem, or prints superblock info if FUSE is unavailable.

Usage:
  ./build/sagefs-fuse <image-path> <mountpoint> [options]
  ./build/sagefs-fuse --info <image-path>

Reads the hex-text image format (see src/imgio.sage) and presents the
filesystem via FUSE (using the fusepy library).  Supports read-write
access: changes are serialised back to the hex-text image on unmount.

If fusepy or libfuse are not installed the script falls back to printing
superblock info.
"""

import os
import sys
import struct
import time

SAGEFS_MAGIC = 0x53414745
S_IFREG = 0x8000
S_IFDIR = 0x4000


def _read_raw(path: str) -> bytes:
    with open(path, "r") as f:
        hexdata = f.read().strip()
    return bytes.fromhex(hexdata)


def _write_raw(path: str, raw: bytes):
    with open(path, "w") as f:
        f.write(raw.hex())


def read_inode_entries(raw: bytes) -> list[dict]:
    """Parse inode directory entries after the 428-byte superblock."""
    entries = []
    off = 428
    while off + 16 <= len(raw):
        ino = struct.unpack_from("<I", raw, off)[0]
        mode = struct.unpack_from("<I", raw, off + 4)[0]
        size = struct.unpack_from("<I", raw, off + 8)[0]
        name_len = struct.unpack_from("<H", raw, off + 12)[0]
        data_len = struct.unpack_from("<H", raw, off + 14)[0]
        entry_off = off + 16
        if entry_off + name_len + data_len > len(raw):
            break
        name = raw[entry_off : entry_off + name_len].decode("ascii", errors="replace")
        data = raw[entry_off + name_len : entry_off + name_len + data_len]
        entries.append({"ino": ino, "mode": mode, "size": size, "name": name, "data": data})
        off = entry_off + name_len + data_len
    return entries


def make_inode_entry(ino: int, mode: int, name: str, data: bytes) -> bytes:
    """Build a binary inode directory entry."""
    name_b = name.encode("ascii", errors="replace")
    buf = struct.pack("<II", ino, mode)
    buf += struct.pack("<I", len(data))
    buf += struct.pack("<H", len(name_b))
    buf += struct.pack("<H", len(data))
    buf += name_b
    buf += data
    return buf


def read_superblock(path: str) -> dict:
    raw = _read_raw(path)
    if len(raw) < 428:
        raise ValueError(f"Image too small: {len(raw)} bytes (need 428)")
    magic = struct.unpack_from("<I", raw, 0)[0]
    if magic != SAGEFS_MAGIC:
        raise ValueError(f"Bad magic: 0x{magic:08X}, expected 0x{SAGEFS_MAGIC:08X}")
    sb = {
        "magic": magic,
        "version_major": struct.unpack_from("<I", raw, 4)[0],
        "version_minor": struct.unpack_from("<I", raw, 8)[0],
        "block_size": struct.unpack_from("<I", raw, 12)[0],
        "segment_size": struct.unpack_from("<I", raw, 16)[0],
        "total_segments": struct.unpack_from("<Q", raw, 20)[0],
        "total_blocks": struct.unpack_from("<Q", raw, 28)[0],
        "free_segments": struct.unpack_from("<Q", raw, 36)[0],
        "root_inode": struct.unpack_from("<Q", raw, 44)[0],
        "checkpoint_ver": struct.unpack_from("<Q", raw, 52)[0],
        "nat_start_blk": struct.unpack_from("<Q", raw, 60)[0],
        "sit_start_blk": struct.unpack_from("<Q", raw, 68)[0],
        "ssa_start_blk": struct.unpack_from("<Q", raw, 76)[0],
        "main_start_blk": struct.unpack_from("<Q", raw, 84)[0],
        "uuid": raw[92:128].rstrip(b"\x00").decode("ascii", errors="replace"),
        "label": raw[128:384].rstrip(b"\x00").decode("ascii", errors="replace"),
        "flags": struct.unpack_from("<I", raw, 384)[0],
        "checksum_algo": struct.unpack_from("<I", raw, 388)[0],
        "compress_algo": struct.unpack_from("<I", raw, 392)[0],
        "encryption_algo": struct.unpack_from("<I", raw, 396)[0],
        "raid_level": struct.unpack_from("<I", raw, 400)[0],
        "create_time": struct.unpack_from("<Q", raw, 404)[0],
        "mount_count": struct.unpack_from("<I", raw, 412)[0],
        "max_mount_count": struct.unpack_from("<I", raw, 416)[0],
        "state": struct.unpack_from("<I", raw, 420)[0],
        "checksum": struct.unpack_from("<I", raw, 424)[0],
    }
    return sb


def print_superblock(sb: dict):
    print(f"  Magic:           0x{sb['magic']:08X}")
    print(f"  Version:         {sb['version_major']}.{sb['version_minor']}")
    print(f"  Block Size:      {sb['block_size']}")
    print(f"  Segment Size:    {sb['segment_size']}")
    print(f"  Total Segments:  {sb['total_segments']}")
    print(f"  Total Blocks:    {sb['total_blocks']}")
    print(f"  Free Segments:   {sb['free_segments']}")
    print(f"  Root Inode:      {sb['root_inode']}")
    print(f"  UUID:            {sb['uuid'] or '(none)'}")
    print(f"  Label:           {sb['label'] or '(none)'}")
    print(f"  Flags:           0x{sb['flags']:08X}")
    print(f"  Checksum Algo:   {sb['checksum_algo']}")
    print(f"  Compress Algo:   {sb['compress_algo']}")
    print(f"  Encryption Algo: {sb['encryption_algo']}")
    print(f"  Raid Level:      {sb['raid_level']}")
    print(f"  State:           {sb['state']}")
    print(f"  Mount Count:     {sb['mount_count']}/{sb['max_mount_count']}")


def build_inode_directory(entries: list[dict]) -> bytes:
    buf = b""
    next_ino = 3
    for entry in entries:
        ino = entry.get("ino", next_ino)
        if ino >= next_ino:
            next_ino = ino + 1
        mode = entry.get("mode", S_IFREG | 0x1A4)
        name = entry.get("name", "")
        data = entry.get("data", b"" if isinstance(entry.get("data"), bytes) else entry.get("data", "").encode())
        if isinstance(data, str):
            data = data.encode()
        buf += make_inode_entry(ino, mode, name, data)
    return buf


def main():
    if len(sys.argv) < 2:
        print("Usage: sagefs-fuse <image> [mountpoint]", file=sys.stderr)
        print("       sagefs-fuse --info <image>", file=sys.stderr)
        sys.exit(1)

    image_path = sys.argv[1]
    if image_path == "--info" and len(sys.argv) >= 3:
        image_path = sys.argv[2]

    if not os.path.exists(image_path):
        print(f"Error: image not found: {image_path}", file=sys.stderr)
        sys.exit(1)

    sb = read_superblock(image_path)
    print(f"SageFS: {image_path}")
    print_superblock(sb)

    if image_path == sys.argv[1] and len(sys.argv) >= 3:
        mountpoint = sys.argv[2]
        extra_opts = sys.argv[3:]

        if not os.path.exists(mountpoint):
            print(f"Error: mount point not found: {mountpoint}", file=sys.stderr)
            sys.exit(1)

        try:
            from fuse import FUSE, FuseOSError, Operations, LoggingMixIn
        except (ImportError, EnvironmentError):
            print("FUSE unavailable (install fusepy + libfuse)", file=sys.stderr)
            print(f"To manually inspect: sagefs-fuse --info {image_path}", file=sys.stderr)
            sys.exit(1)

        class SageFSFUSE(LoggingMixIn, Operations):
            def __init__(self, image_path):
                self.image_path = os.path.abspath(image_path)
                self.sb = read_superblock(self.image_path)
                self.fd_counter = 0
                self.fds = {}
                self.dirty = False
                self.next_ino = 3

                raw = _read_raw(self.image_path)
                self.inode_entries = read_inode_entries(raw)

                if not self.inode_entries:
                    self.inode_entries = []

                self.inode_by_name = {}
                for entry in self.inode_entries:
                    name = entry["name"]
                    self.inode_by_name[name] = entry
                    if entry["ino"] >= self.next_ino:
                        self.next_ino = entry["ino"] + 1

            def _save(self):
                raw = _read_raw(self.image_path)
                superblock = raw[:428]
                inode_dir = build_inode_directory(self.inode_entries)
                _write_raw(self.image_path, superblock + inode_dir)

            def _path_to_name(self, path):
                return path.lstrip("/")

            def getattr(self, path, fh=None):
                st = {
                    "st_dev": 0, "st_ino": 0, "st_nlink": 1,
                    "st_mode": 0o555, "st_uid": os.getuid(),
                    "st_gid": os.getgid(), "st_size": 0,
                    "st_atime": int(time.time()),
                    "st_mtime": int(time.time()),
                    "st_ctime": int(time.time()),
                }
                if path == "/":
                    st["st_mode"] = 0o555 | 0o40000
                    st["st_nlink"] = 2
                    st["st_size"] = 4096
                else:
                    name = self._path_to_name(path)
                    if name in self.inode_by_name:
                        entry = self.inode_by_name[name]
                        st["st_mode"] = entry["mode"]
                        st["st_size"] = entry["size"]
                    else:
                        raise FuseOSError(2)
                return st

            def readdir(self, path, fh):
                entries = [".", ".."]
                if path == "/":
                    for name in self.inode_by_name:
                        entries.append(name)
                return entries

            def open(self, path, flags):
                name = self._path_to_name(path)
                if name not in self.inode_by_name:
                    raise FuseOSError(2)
                self.fd_counter += 1
                self.fds[self.fd_counter] = name
                return self.fd_counter

            def read(self, path, size, offset, fh):
                name = self._path_to_name(path)
                entry = self.inode_by_name.get(name)
                if entry is None:
                    raise FuseOSError(2)
                data = entry["data"]
                if isinstance(data, str):
                    data = data.encode()
                return data[offset : offset + size]

            def write(self, path, data, offset, fh):
                name = self._path_to_name(path)
                entry = self.inode_by_name.get(name)
                if entry is None:
                    raise FuseOSError(2)
                existing = entry["data"]
                if isinstance(existing, str):
                    existing = existing.encode()
                if offset > len(existing):
                    existing = existing + b"\x00" * (offset - len(existing))
                new_data = existing[:offset] + data + existing[offset + len(data):]
                entry["data"] = new_data
                entry["size"] = len(new_data)
                self.dirty = True
                return len(data)

            def truncate(self, path, length, fh=None):
                name = self._path_to_name(path)
                entry = self.inode_by_name.get(name)
                if entry is None:
                    raise FuseOSError(2)
                existing = entry["data"]
                if isinstance(existing, str):
                    existing = existing.encode()
                entry["data"] = existing[:length]
                entry["size"] = length
                self.dirty = True

            def create(self, path, mode, fi=None):
                name = self._path_to_name(path)
                if name in self.inode_by_name:
                    raise FuseOSError(17)
                ino = self.next_ino
                self.next_ino += 1
                entry = {"ino": ino, "mode": S_IFREG | 0x1A4, "size": 0, "name": name, "data": b""}
                self.inode_entries.append(entry)
                self.inode_by_name[name] = entry
                self.dirty = True
                self.fd_counter += 1
                self.fds[self.fd_counter] = name
                return self.fd_counter

            def unlink(self, path):
                name = self._path_to_name(path)
                if name not in self.inode_by_name:
                    raise FuseOSError(2)
                self.inode_entries = [e for e in self.inode_entries if e["name"] != name]
                del self.inode_by_name[name]
                self.dirty = True

            def rmdir(self, path):
                raise FuseOSError(39)

            def mkdir(self, path, mode):
                name = self._path_to_name(path)
                if name in self.inode_by_name:
                    raise FuseOSError(17)
                ino = self.next_ino
                self.next_ino += 1
                entry = {"ino": ino, "mode": S_IFDIR | 0x1ED, "size": 4096, "name": name, "data": b""}
                self.inode_entries.append(entry)
                self.inode_by_name[name] = entry
                self.dirty = True

            def rename(self, old, new):
                old_name = self._path_to_name(old)
                new_name = self._path_to_name(new)
                if old_name not in self.inode_by_name:
                    raise FuseOSError(2)
                entry = self.inode_by_name.pop(old_name)
                entry["name"] = new_name
                self.inode_by_name[new_name] = entry
                self.dirty = True

            def release(self, path, fh):
                self.fds.pop(fh, None)

            def statfs(self, path):
                return {
                    "f_bsize": self.sb["block_size"],
                    "f_blocks": self.sb["total_blocks"],
                    "f_bfree": self.sb["free_segments"] * self.sb["segment_size"],
                    "f_bavail": self.sb["free_segments"] * self.sb["segment_size"],
                    "f_files": max(self.next_ino - 1, 1),
                    "f_ffree": 0,
                }

            def destroy(self, path):
                if self.dirty:
                    print("SageFS: writing changes to", self.image_path)
                    self._save()

        print(f"SageFS: mounting {image_path} on {mountpoint}")
        FUSE(
            SageFSFUSE(image_path),
            mountpoint,
            foreground=True,
            nothreads=True,
            *extra_opts,
        )
    else:
        print("SageFS: inspection only (no mount point specified)")


if __name__ == "__main__":
    main()
